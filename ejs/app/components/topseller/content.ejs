<div class="topseller">
    <a href="<%= topseller.link %>" class="details">
        <div class="content">
            <span class="number"><%= numberItem %></span>
            <span class="title">
                <%= topseller.title %>
            </span>
        </div>
        <img src="./assets/media/images/<%= topseller.image.src %>" alt="<%= topseller.image.alt %>">
    </a>
    <div class="background-wrapper w-100 h-100 position-absolute"></div>
</div>