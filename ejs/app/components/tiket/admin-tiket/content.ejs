
   
    <div class="admin-tiket d-flex justify-content-space-between bw-1 border-primary-color bg-primary-light-color border-style-solid radius-all-normal py-6 px-8 flex-lg-column">
        <div class="d-flex justify-content-start gap-10">
            <div class="d-flex gap-2 justify-content-center align-items-start">
                <div class="wraper-user-image bg-primary-color d-flex justify-content-center align-items-center">
                    <i class="fa-regular fa-headset on-primary-color icon-headset"></i>
                </div>

                <div class="d-flex flex-column gap-4">
                    <p class="font-weight-bold text-color "> <%= adminTiket.title %></p>
                    <p class="secondary-text-color "><%= adminTiket.subtitle %></p>
                </div>
            </div>
            <div class="py-4">
                <p class="secondary-text-color ">
                   <%= adminTiket.description1 %><br>
                   <%= adminTiket.description2 %><br>
                   <%= adminTiket.description3 %><br>
                   <%= adminTiket.description4 %>
                </p>
            </div>
        </div>
        <div class="d-flex flex-column gap-2 align-items-end">
            <span class="secondary-text-color "><%= adminTiket.date %></span>
            <span class="border-color border-style-solid bw-1 radius-all-extra-small px-3 py-1 txt-size-title bg-secondary-color text-color"> <%= adminTiket.replay %></span>
        </div>
    </div>

