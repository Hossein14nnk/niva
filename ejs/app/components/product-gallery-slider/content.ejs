<div class="product-gallery slider">
    <div class="slider-wrapper slider-loop">
        <div class="slider-container">
            <%_ for(let i = 0; i < productGallerySlider.sliderContents.length; i++){ -%>
                <div id="<%= productGallerySlider.sliderContents[i].id %>" class="slider-content">
                    <img src="<%= getMedia(lang, `products/mobile-${i + 1}.webp`, 'images'); %>" alt="">
                </div>
            <%_ } -%>
        </div>
    </div>
    <div class="slider-toggles">
        <%_ for(let i = 0; i < productGallerySlider.sliderToggles.length; i++){ -%>
            <img class="slider-toggle" data-slider-id="<%= productGallerySlider.sliderToggles[i].id %>" src="<%= getMedia(lang, `products/mobile-${i + 1}.webp`, 'images'); %>" alt="">
        <%_ } -%>
    </div>
</div>