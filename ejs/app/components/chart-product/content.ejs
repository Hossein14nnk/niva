<dialog id="chartProduct" class="modal-container video-modal show" style="display: flex;">
	<div class="modal-content d-flex justify-content-center align-items-center" style="position: absolute; top: 0px; left: 0px;">
		<div class="d-flex flex-column px-6 radius-all-medium bg-color w-40 w-lg-50 w-sm-75">
			<div class="d-flex justify-content-space-between align-items-center py-6 border-color">
				<p class="txt-size-high-title font-weight-semi-bold text-color"> <%= productChart.chart %></p>
				<i class="fa-solid fa-close modal-close secondary-text-color txt-size-big-title"></i>
			</div>
			<div class="d-flex flex-column align-items-start gap-2 py-4 border-color">
				<canvas id="productChart" style="display: block; box-sizing: border-box; height: 245.8px; width: 491.6px;" height="245" width="491"></canvas>
			</div>
		</div>
	</div>
</dialog>