<%_ const userName = _.camelCase(story.userName) -%>
<%_ const userNameAllowed = /^[a-zA-Z0-9_]+$/; -%>
<%_ if (!userNameAllowed.test(userName)) { -%>
	<% throw new Error(`Error: Only English letters, numbers and _.\n${_.camelCase(story.userName)} is not allowed.\n`);%>
<%_ } -%>
<dialog id="story<%= _.upperFirst(userName) %>" class="modal-container story-modal">
	<div class="modal-content">
		<div class="slider ltr slider-draggable slider-loop w-100 h-100 d-flex flex-column align-items-center gap-4" data-slider-timer="<%= dataSliderTimer%>">
			<div class="slider-wrapper h-100">
				<div class="slider-container">
					<%_ for(let i = 0; i < story.contents.length; i++){ -%>
						<%_ let sliderStatus = ""; -%>
						<%_ if (i == 0){ -%>
							<%_ sliderStatus = "active"; -%>
						<%_ } -%>
						<div id="story<%= _.upperFirst(userName) %>Content<%= i %>" class="slider-content position-relative d-flex flex-column justify-content-center align-items-center <%= sliderStatus %>">
							<div class="story-content d-flex justify-content-center align-items-center">
								<span class="shadow-1"></span>
								<span class="shadow-2"></span>
								<span class="shadow-3"></span>
								<img class="content radius-all-medium bg-black-color object-contain w-100 h-100" src="<%= getMedia(lang, `product/laptop-${i + 1}`, 'images'); %>" alt="" />
								<div class="w-100 h-100 position-absolute top-0 right-0 px-3 py-3 d-flex flex-column align-items-center justify-content-space-between">
									<div class="w-100 h-100 d-flex flex-column">
										<div class="story-timelines grid-<%= story.contents.length %>">
											<%_ for(let j = 0; j < story.contents.length; j++){ -%>
												<%_ if(j === i){ -%>
											<div class="timeline active"></div>
												<%_ } else { -%>
											<div class="timeline"></div>
												<%_ } -%>
											<%_ } -%>
										</div>
										<div class="d-flex flex-row align-items-center gap-4 z-index-10">
											<a href="<%= story.contents[i].profile.image.link %>" class="product-img w-20 p-2 radius-all-small aspect-ratio-1x1 bg-secondary-color d-flex align-items-center">
												<img src="<%= getMedia(lang, `products/mobile-${i + 1}`, 'images'); %>" alt="" class="w-100" />
											</a>
											<a href="<%= story.contents[i].profile.title.link %>" class="product-name radius-all-full secondary-color w-100 ellipsis-1 py-2 px-3 txt-size-normal font-weight-bold"><%= story.contents[i].profile.title.text %></a>
											<div class="modal-close">
												<i class="fa-solid fa-close secondary-color"></i>
											</div>
										</div>
									</div>
	
									<div class="w-100 d-flex flex-row px-6 py-4 gap-10 z-index-10">
										<%_ const numberAllowed = /^[0-9]+$/; -%>
										<%_ if (!numberAllowed.test(story.contents[i].likeCount) || !numberAllowed.test(story.contents[i].commentCount)) { -%>
											<% throw new Error(`Error: Only numbers.\n"likeCount": ${story.contents[i].likeCount} or "commentCount": ${story.contents[i].commentCount} is not allowed.\n`);%>
										<%_ } -%>
										<div class="like-story cursor-pointer d-flex flex-column gap-1 align-items-center">
											<i class="fa-regular fa-heart on-primary-color txt-size-big-title"></i>
											<span class="count txt-size-title on-primary-color"><%= story.contents[i].likeCount %></span>
										</div>
										<div class="cursor-pointer d-flex flex-column gap-1 align-items-center">
											<i class="fa-regular fa-comment on-primary-color txt-size-big-title"></i>
											<span class="txt-size-title on-primary-color"><%= story.contents[i].commentCount %></span>
										</div>
									</div>
								</div>
	
								<div class="slider-arrows position-absolute d-flex w-100 h-100 justify-content-space-between align-items-center">
									<div class="slider-arrow-prev w-30 h-100 bg-transparent-color"></div>
									<div class="slider-arrow-next w-30 h-100 bg-transparent-color"></div>
								</div>
							</div>
						</div>
					<%_ } -%>
				</div>
			</div>
		</div>
	</div>
</dialog>