			<div class="d-flex justify-content-center align-items-center gap-4">
				<a href="#" class="grow-1">
					<button class="w-100 txt-size-high-title cursor-pointer font-weight-semi-bold border-color bw-1 border-style-solid radius-all-normal py-2 bg-color on-secondary-color"><%= t.dialog.cartProduct.buttonOne %></button>
				</a>
				<a href="#" class="grow-1">
					<button class="w-100 txt-size-high-title cursor-pointer font-weight-semi-bold radius-all-normal py-2 bg-button-color on-primary-color"><%= t.dialog.cartProduct.buttonTwo %></button>
				</a>
			</div>
		</div>
	</div>
</dialog>
<dialog id="reviewSubmit" class="modal-container reviewsubmit">
	<div class="modal-content">
		<div class="modal-content d-flex justify-content-center align-items-center">
			<div class="box d-flex flex-column gap-4 align-items-center bg-color radius-all-large p-8 w-40 w-lg-50 w-sm-75">
				<i class="fa-solid fa-close modal-close secondary-text-color align-self-end"></i>
				<p class="txt-size-mid-title font-weight-semi-bold on-secondary-color"><%= t.dialog.reviewSubmit.mainText %></p>
				<a href="#" class="w-100">
					<button class="w-100 txt-size-high-title cursor-pointer font-weight-semi-bold radius-all-normal py-2 bg-button-color on-primary-color"><%= t.dialog.reviewSubmit.buttonText %></button>
				</a>
			</div>
		</div>
	</div>
</dialog>
<dialog id="sharingProduct" class="modal-container sharing-modal">
	<div class="modal-content d-flex justify-content-center align-items-center">
		<div class="d-flex flex-column px-6 radius-all-medium bg-color w-40 w-lg-50 w-sm-75">
			<div class="d-flex justify-content-space-between align-items-center py-6 border-color bb-style-solid bw-1">
				<p class="txt-size-high-title font-weight-semi-bold on-secondary-color"><%= t.dialog.sharingProduct.title %></p>
				<i class="fa-solid fa-close modal-close secondary-text-color txt-size-big-title"></i>
			</div>
			<div class="d-flex flex-column align-items-start gap-2 py-4 border-color bb-style-solid bw-1">
				<p class="txt-size-mid-title font-weight-bold on-secondary-color"><%= t.dialog.sharingProduct.shairText %></p>
				<div class="d-flex gap-4">
					<img class="w-6 aspect-ratio-1x1 object-contain" src="<%= getMedia(lang, 'products/mobile-15.webp', 'images'); %>" alt="" />
					<p class="txt-size-big font-weight-medium on-secondary-color"><%= t.dialog.sharingProduct.product.name %></p>
				</div>
			</div>
			<div class="d-flex align-items-start gap-2 py-4 border-color bb-style-solid bw-1">
				<a href="facebook" class="d-flex flex-column align-items-center justify-content-center grow-1 gap-2 bw-1 border-color bie-style-solid">
					<i class="fa-brands fa-facebook txt-size-high-title on-secondary-color"></i>
					<p class="txt-size-title font-weight-medium on-secondary-color"><%= t.dialog.sharingProduct.socialMediaOne %></p>
				</a>
				<a href="whatsapp" class="d-flex flex-column align-items-center justify-content-center grow-1 gap-2 bw-1 border-color bie-style-solid">
					<i class="fa-brands fa-whatsapp txt-size-high-title on-secondary-color"></i>
					<p class="txt-size-title font-weight-medium on-secondary-color"><%= t.dialog.sharingProduct.socialMediaTwo %></p>
				</a>
				<a href="telegram" class="d-flex flex-column align-items-center justify-content-center grow-1 gap-2">
					<i class="fa-brands fa-telegram txt-size-high-title on-secondary-color"></i>
					<p class="txt-size-title font-weight-medium on-secondary-color"><%= t.dialog.sharingProduct.socialMediaThree %></p>
				</a>
			</div>
			<div class="d-flex flex-column align-items-center gap-2 py-6">
				<div class="d-flex align-items-center flex-row-reverse gap-6 copy-address">
					<div class="alert-toggle d-flex align-items-center cursor-pointer gap-4 font-size-19px text-variantly-color flex-row-reverse copy-item" data-alert-title="<%= t.dialog.sharingProduct.components.copy.alertText %>">
						<i class="d-flex icon-copy on-secondary-color"></i>
						<p class="txt-size-extra-title font-weight-semi-bold on-secondary-color"><%= t.dialog.sharingProduct.components.copy.text %></p>
					</div>
					<p class="text-color font-weight-100 txt-size-title d-none site-url"></p>
				</div>
			</div>
		</div>
	</div>
</dialog>
<dialog id="videoProduct" class="modal-container video-modal">
	<div class="modal-content d-flex justify-content-center align-items-center">
		<div class="d-flex flex-column px-6 radius-all-medium bg-color w-40 w-lg-50 w-sm-75">
			<div class="d-flex justify-content-space-between align-items-center py-6 border-color">
				<p class="txt-size-high-title font-weight-semi-bold text-color"><%= t.dialog.videoProduct.title %></p>
				<i class="fa-solid fa-close modal-close secondary-text-color txt-size-big-title"></i>
			</div>
			<div class="d-flex flex-column align-items-start gap-2 py-4 border-color">
				<video controls="" class="radius-all-small w-100">
					<source src="<%= getMedia(null, 'video.mp4', 'videos'); %>" />
				</video>
			</div>
		</div>
	</div>
</dialog>
<dialog id="chartProduct" class="modal-container video-modal">
	<div class="modal-content d-flex justify-content-center align-items-center">
		<div class="d-flex flex-column px-6 radius-all-medium bg-color w-40 w-lg-50 w-sm-75">
			<div class="d-flex justify-content-space-between align-items-center py-6 border-color">
				<p class="txt-size-high-title font-weight-semi-bold text-color"><%= t.dialog.chartProduct.title %></p>
				<i class="fa-solid fa-close modal-close secondary-text-color txt-size-big-title"></i>
			</div>
			<div class="d-flex flex-column align-items-start gap-2 py-4 border-color">
				<canvas id="productChart" style="display: block; box-sizing: border-box; height: 0px; width: 0px" height="0" width="0"></canvas>
			</div>
		</div>
	</div>
</dialog>
<dialog id="cheaperPrice" class="modal-container">
	<div class="modal-content d-flex justify-content-center align-items-center">
		<div class="report-product d-flex flex-column px-6 py-6 radius-all-medium bg-color w-40 w-lg-50 w-sm-75">
			<div class="d-flex flex-row align-content-center justify-content-space-between pb-4">
				<span class="txt-size-title font-weight-bold"><%= t.dialog.cheaperPrice.title %></span>
				<i class="modal-close fa-solid fa-close secondary-light-color"></i>
			</div>
			<form class="d-flex flex-column gap-4" action="#">
				<div class="d-flex flex-column gap-1">
					<div>
						<label for="one" class="txt-size-big font-weight-medium"><%= t.dialog.cheaperPrice.fieldOne %></label>
						<input type="text" id="one" class="w-100 px-2 py-2 outline-unset bg-secondary-color radius-all-small border-b-none border-l-none border-r-none border-t-none" />
					</div>

					<div>
						<label for="two" class="txt-size-big font-weight-medium"><%= t.dialog.cheaperPrice.fieldTwo %></label>
						<input type="text" id="two" class="w-100 px-2 py-2 outline-unset bg-secondary-color radius-all-small border-b-none border-l-none border-r-none border-t-none" />
					</div>
				</div>
				<button type="submit" class="bg-btn-hover w-100 py-3 bg-button-color button-text-color radius-all-small font-weight-medium"><%= t.dialog.cheaperPrice.buttonText %></button>
			</form>
		</div>
	</div>
</dialog>
<dialog id="reportProduct" class="modal-container">
	<div class="modal-content d-flex justify-content-center align-items-center">
		<form class="report-card d-flex flex-column px-6 py-6 radius-all-medium bg-color w-40 w-lg-50 w-sm-75 gap-4" action="#">
			<div class="d-flex flex-row align-content-center justify-content-space-between">
				<span class="txt-size-title font-weight-bold"><%= t.dialog.reportProduct.title %></span>
				<i class="modal-close fa-solid fa-close secondary-light-color"></i>
			</div>
			<div class="d-flex flex-column gap-2">
				<div class="d-flex flex-row align-content-center gap-2">
					<input type="radio" name="select" id="one" />
					<label class="txt-size-big font-weight-medium" for="one"><%= t.dialog.reportProduct.radioOne %></label>
				</div>
