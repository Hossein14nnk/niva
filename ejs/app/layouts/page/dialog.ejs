<dialog id="cartProduct" class="modal-container cart-modal">
	<div class="modal-content d-flex justify-content-center align-items-center">
		<div class="box d-flex flex-column bg-color radius-all-large p-8 w-30 w-xl-40 w-lg-50 w-sm-75">
			<i class="fa-solid fa-close modal-close secondary-text-color align-items-end"></i>
			<div class="radius-all-medium border-color bw-1 border-style-solid mt-8 p-4">
				<div class="d-flex gap-4">
					<img class="w-14 aspect-ratio-1x1 object-contain" src="<%= getMedia(lang, 'products/mobile-14.webp', 'images'); %>" alt="" />
					<p class="txt-size-title font-weight-medium on-secondary-color"><%= t.dialog.cartProduct.product.name %></p>
				</div>
				<div class="d-flex justify-content-space-between align-items-center">
					<div class="d-flex align-items-center justify-content-end">
