					<div class="qty d-flex justify-content-space-between py-2 px-2 radius-all-small align-items-center secondary-text-color bg-secondary-color">
						<span class="qty-plus radius-all-small bg-color py-2 px-4 font-weight-bold txt-size-big-title">+</span>
						<input class="qty-value font-weight-bold txt-size-big-title" value="0" max="10" min="1" />
						<span class="qty-minus radius-all-small bg-color py-2 px-4 font-weight-bold txt-size-big-title">-</span>
					</div>
				</div>
			</div>
			<div class="d-flex justify-content-space-between align-items-center py-8">
				<p class="txt-size-mid-title font-weight-semi-bold on-secondary-color"><%= t.dialog.cartProduct.priceText %></p>
