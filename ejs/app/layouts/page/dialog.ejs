<dialog id="suggestion" class="modal-container">
	<div class="modal-content justify-content-center">
		<div class="suggestion-card w-40 w-lg-50 w-sm-75 radius-all-normal background-color py-8 px-5 d-flex flex-column gap-6 position-relative bw-1 border-style-solid border-color bg-on-primary-color">
			<div class="header-box pb-6 d-flex align-items-center justify-content-space-between bw-1 bb-style-solid border-on-secondary-color top-0">
				<p class="text-color txt-size-big-title font-weight-bold"><%= t.dialog.suggestion.title %></p>
				<i class="modal-close fa-solid fa-close d-flex justify-content-center align-items-center py-1 px-2 border-on-secondary-color bw-2 border-style-solid radius-all-full text-color txt-size-big-title font-weight-bold"></i>
			</div>
			<form class="w-100 px-4 py-4 d-flex flex-column gap-10 align-items-center overflow-y-scroll">
				<div class="product-detail w-100 py-10 radius-all-small position-relative justify-content-center align-items-center d-flex">
					<p class="txt-size-extra-title mis-12"><%= t.dialog.suggestion.product.name %></p>
					<img class="w-15 top-0 right-0 position-absolute" src="<%= getMedia(lang, 'products/mobile-16.webp', 'images'); %>" alt=""/>
				</div>
				<div class="d-flex flex-column gap-6 justify-content-center">
					<p class="font-weight-black txt-size-extra-title"><%= t.dialog.suggestion.rate %></p>
					<div class="d-flex align-items-center gap-2">
						<i class="fa-solid fa-star txt-size-big-title"></i>
						<i class="fa-solid fa-star txt-size-big-title"></i>
						<i class="fa-solid fa-star txt-size-big-title"></i>
						<i class="fa-solid fa-star txt-size-big-title"></i>
						<i class="fa-solid fa-star txt-size-big-title"></i>
					</div>
				</div>
				<div class="form-box w-100 d-flex flex-column gap-10 justify-content-start">
					<p class="txt-size-high-title font-weight-bold"><%= t.dialog.suggestion.opinion %></p>
					<input type="text" id="suggest" required="" placeholder="<%= t.dialog.suggestion.fieldOne %>" class="bw-2 border-color border-style-solid radius-all-small px-6 py-6 txt-size-extra-title font-weight-bold justify-content-start" />
					<label for="suggest-positive" class="d-flex justify-content-space-between bw-2 border-color border-style-solid radius-all-small px-6 py-6 txt-size-extra-title text-secondary-color">
						<input type="text" id="suggest-positive" placeholder="<%= t.dialog.suggestion.fieldTwo %>" class="txt-size-extra-title font-weight-bold" style="border: none" />
						<button class="font-weight-bold secondary-text-color"><%= t.dialog.suggestion.submitButton %></button>
					</label>
					<label for="suggest-negetive" class="d-flex justify-content-space-between bw-2 border-color border-style-solid radius-all-small px-6 py-6 txt-size-extra-title text-secondary-color">
						<input type="text" id="suggest-negetive" placeholder="<%= t.dialog.suggestion.fieldThree %>" class="txt-size-extra-title font-weight-bold" style="border: none" />
						<button class="font-weight-bold secondary-text-color"><%= t.dialog.suggestion.submitButton %></button>
					</label>
				</div>
				<div class="d-flex flex-column gap-8 w-100">
					<div class="d-flex align-items-center gap-2">
						<input class="bw-2" type="checkbox" id="unknown" />
						<p class="txt-size-high-title font-weight-bold"><%= t.dialog.suggestion.checkout %></p>
					</div>
					<p class="txt-size-high-title font-weight-bold"><%= t.dialog.suggestion.acceptRules.partOne %> <a href="#" class="txt-decoration-style-solid txt-decoration-underline primary-color">قوانین <%= t.dialog.suggestion.acceptRules.partTwo %></a><%= t.dialog.suggestion.acceptRules.partFour %></p>
				</div>
				<button type="submit" class="w-100 bg-primary-color on-primary-color txt-size-extra-title font-weight-bold py-4 radius-all-small txt-align-center cart-button"><%= t.dialog.suggestion.buttonText %></button>
			</form>
		</div>
	</div>
</dialog>