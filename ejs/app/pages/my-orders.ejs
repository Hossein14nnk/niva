<!doctype html>
<html dir="rtl">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>my-orders</title>
	<link rel="stylesheet" href="../assets/css/miz.min.css" />
	<link rel="stylesheet" href="../assets/css/style.min.css" />
	<link rel="stylesheet" href="../assets/vendors/swiper/swiper-bundle-min.css" />
	<link rel="stylesheet" href="../assets/vendors/swiper/style.css" />
	<link rel="stylesheet" href="../assets/vendors/snap-alert-js-main/snapAlert.min.css" />
	<link rel="stylesheet" href="../assets/icons/fontawesome/css/all.min.css" />
	<link rel="stylesheet" href="../assets/icons/icomoon/css/all.min.css" />
	<link rel="icon" type="image/x-icon" href="../assets/media/images/logo.webp" />
</head>

<body class="font-fa-primary">
	<main id="my-orders" class="orders-page">
		<section id="" class="section gap-10 align-items-start d-grid grid-template">
			<aside class="">
				<%- include('../components/sidebar-menu/content.ejs', {sidebarMenu: t.pages.myAddress.components.sidebarMenu}); %>
			</aside>
			<div class="container gap-6">
				<div>
					<div class="block gap-1">
						<svg class="auth-icon" xmlns="http://www.w3.org/2000/svg" width="25" height="25"
							viewBox="0 0 18 19" fill="none">
							<path
								d="M8.96611 9.54044C6.93565 9.54044 5.28964 7.89443 5.28964 5.86397C5.28964 3.83351 6.93565 2.1875 8.96611 2.1875C10.9966 2.1875 12.6426 3.83351 12.6426 5.86397C12.6426 7.89443 10.9966 9.54044 8.96611 9.54044Z"
								stroke="#ED1D5A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
							<path
								d="M2.65122 17.9312C2.65122 15.0857 5.4821 12.7842 8.96739 12.7842C12.4527 12.7842 15.2836 15.0857 15.2836 17.9312"
								stroke="#ED1D5A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
						</svg>
						<h3 class="txt-size-big-title font-weight-bold"><%= t.pages.myOrders.myAccount %></h3>
					</div>
					<div class="block gap-2 txt-size-title align-items-center">
						<a class="secondary-text-color" href="../index.html"><%= t.pages.myOrders.home %></a>
						<i class="icon-arr-left txt-size-small opacity-5 on-secondary-color"></i>
						<a class="secondary-text-color" href="#"><%= t.pages.myOrders.account %></a>
						<i class="icon-arr-left txt-size-small opacity-5 on-secondary-color"></i>
						<a class="secondary-text-color" href="#"><%= t.pages.myOrders.detailsAccount %></a>
					</div>
				</div>
				<div class="block flex-column w-100 gap-6 box-shadow radius-all-medium p-6">
					<div class="div gap-2">
						<svg class="auth-icon" xmlns="http://www.w3.org/2000/svg" width="23" height="23"
							viewBox="0 0 18 19" fill="none">
							<path
								d="M8.96611 9.54044C6.93565 9.54044 5.28964 7.89443 5.28964 5.86397C5.28964 3.83351 6.93565 2.1875 8.96611 2.1875C10.9966 2.1875 12.6426 3.83351 12.6426 5.86397C12.6426 7.89443 10.9966 9.54044 8.96611 9.54044Z"
								stroke="#E80645" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
							<path
								d="M2.65122 17.9312C2.65122 15.0857 5.4821 12.7842 8.96739 12.7842C12.4527 12.7842 15.2836 15.0857 15.2836 17.9312"
								stroke="#E80645" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
						</svg>
						<h3 class="txt-size-mid-title font-weight-bold"><%= t.pages.myOrders.myAccount %></h3>
					</div>
					<form action="" class="d-flex gy-5 gx-3 flex-wrap w-100">
						<div class="d-flex flex-column gap-1 col-4 col-md-4">
							<label for="name" class="d-flex"><%= t.pages.myOrders.forms.fitstNameLabel %></label>
							<input id="name" placeholder="<%= t.pages.myOrders.forms.fitstName %>" type="text" required=""
								class="bw-1 border-color border-style-solid radius-all-small px-4 py-3">
						</div>
						<div class="d-flex flex-column gap-1 col-4 col-md-4">
							<label for="name" class="d-flex"><%= t.pages.myOrders.forms.lastNameLabel %></label>
							<input id="name" placeholder="<%= t.pages.myOrders.forms.lastName %>" type="text" required=""
								class="bw-1 border-color border-style-solid radius-all-small px-4 py-3">
						</div>
						<div class="d-flex flex-column gap-1 col-4 col-md-4">
							<label for="family" class="d-flex"><%= t.pages.myOrders.forms.emailLabel %></label>
							<input type="email" placeholder="<%= t.pages.myOrders.forms.email %>" id="family" required=""
								class="bw-1 border-color border-style-solid radius-all-small px-4 py-3">
						</div>
						<div class="d-flex flex-column gap-1 col-6">
							<label for="post-address" class="d-flex"><%= t.pages.myOrders.forms.phoneNumberLabel %></label>
							<input type="tel" placeholder="<%= t.pages.myOrders.forms.phoneNumber %>" id="post-address"
								class="bw-1 border-color border-style-solid radius-all-small px-4 py-3">
						</div>
						<div class="d-flex flex-column gap-1 col-6">
							<label for="code-address" class="d-flex"><%= t.pages.myOrders.forms.dateLabel %></label>
							<input type="date" placeholder="1378/10/30" placeholder="1378/10/30" id="code-address"
								class="bw-1 border-color border-style-solid radius-all-small px-4 py-3">
						</div>
					</form>
					<a href="#"
						class="bg-btn-hover d-flex flex-row align-self-center align-items-center gap-2 gap-md-3 py-3 py-sm-3 pie-4 pis-4 bg-secondary-color radius-all-small bg-button-color">
						<i class="fa-solid fa-bag-shopping button-text-color d-sm-none"></i>
						<span class="button-text-color font-weight-bold"><%= t.pages.myOrders.saveChanges %></span>
					</a>
				</div>
				<div class="block flex-column w-100 gap-4 box-shadow radius-all-medium p-6">
					<div class="div gap-2">
						<svg class="auth-icon" xmlns="http://www.w3.org/2000/svg" width="23" height="23"
							viewBox="0 0 18 19" fill="none">
							<path
								d="M8.96611 9.54044C6.93565 9.54044 5.28964 7.89443 5.28964 5.86397C5.28964 3.83351 6.93565 2.1875 8.96611 2.1875C10.9966 2.1875 12.6426 3.83351 12.6426 5.86397C12.6426 7.89443 10.9966 9.54044 8.96611 9.54044Z"
								stroke="#E80645" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
							<path
								d="M2.65122 17.9312C2.65122 15.0857 5.4821 12.7842 8.96739 12.7842C12.4527 12.7842 15.2836 15.0857 15.2836 17.9312"
								stroke="#E80645" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
						</svg>
						<h3 class="txt-size-high-title font-weight-bold"><%= t.pages.myOrders.accountSecurity %></h3>
					</div>
					<div class="d-flex justify-content-space-between w-100  bw-1 bb-style-solid border-color pb-3">
						<div class="d-flex flex-column">
							<span class="txt-size-mid-title font-weight-semi-bold"><%= t.pages.myOrders.password %></span>
							<span class="txt-size-mid-title secondary-text-color"><%= t.pages.myOrders.enterPassword %></span>
						</div>
						<a href="#"
							class="bg-primary-light-color d-flex flex-row align-self-center align-items-center gap-2 gap-md-3 py-3 py-sm-3 pie-4 pis-4 radius-all-small">
							<i class="fa-solid fa-bag-shopping primary-color d-sm-none"></i>
							<span class="primary-color font-weight-bold"><%= t.pages.myOrders.changePassword %></span>
						</a>
					</div>
					<div class="d-flex justify-content-space-between w-100  bw-1 bb-style-solid border-color pb-3">
						<div class="d-flex flex-column">
							<span class="txt-size-mid-title font-weight-semi-bold"><%= t.pages.myOrders.changephoneNumber %></span>
							<span class="txt-size-mid-title secondary-text-color"><%= t.pages.myOrders.descriptionphoneNumber %>
							</span>
						</div>
						<a href="#"
							class="bg-primary-light-color d-flex flex-row align-items-center gap-2 gap-md-3 py-3 py-sm-3 pie-4 pis-4 radius-all-small">
							<i class="fa-solid fa-bag-shopping primary-color d-sm-none"></i>
							<span class="primary-color font-weight-bold"><%= t.pages.myOrders.enterphoneNumber %></span>
						</a>
					</div>

					<div class="d-flex w-100 flex-column">
						<span class="txt-size-mid-title font-weight-semi-bold"><%= t.pages.myOrders.connectedDevices %></span>
						<span class="txt-size-mid-title secondary-text-color"><%= t.pages.myOrders.management %>
						</span>
					</div>
				</div>
				<div class="block flex-column w-100 gap-4 box-shadow radius-all-medium p-6">
					<div class="div gap-2">
						<svg class="auth-icon" xmlns="http://www.w3.org/2000/svg" width="23" height="23"
							viewBox="0 0 18 19" fill="none">
							<path
								d="M8.96611 9.54044C6.93565 9.54044 5.28964 7.89443 5.28964 5.86397C5.28964 3.83351 6.93565 2.1875 8.96611 2.1875C10.9966 2.1875 12.6426 3.83351 12.6426 5.86397C12.6426 7.89443 10.9966 9.54044 8.96611 9.54044Z"
								stroke="#E80645" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
							<path
								d="M2.65122 17.9312C2.65122 15.0857 5.4821 12.7842 8.96739 12.7842C12.4527 12.7842 15.2836 15.0857 15.2836 17.9312"
								stroke="#E80645" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							</path>
						</svg>
						<h3 class="txt-size-high-title font-weight-bold"><%= t.pages.myOrders.notificationSettings %></h3>
					</div>
					<div class="d-flex justify-content-space-between w-100  bw-1 bb-style-solid border-color pb-3">
						<div class="d-flex flex-column">
							<span class="txt-size-mid-title font-weight-semi-bold"><%= t.pages.myOrders.emailNotifications %></span>
							<span class="txt-size-mid-title secondary-text-color"><%= t.pages.myOrders.receive %>
							</span>
						</div>
						<div class="div justify-content-center align-items-center">
							<div class="switcher d-flex align-items-center radius-all-large active">
								<div class="ball radius-all-large bg-on-secondary-color"></div>
							</div>
						</div>
					</div>
					<div class="d-flex justify-content-space-between w-100">
						<div class="d-flex flex-column">
							<span class="txt-size-mid-title font-weight-semi-bold"><%= t.pages.myOrders.smsNotification %></span>
							<span class="txt-size-mid-title secondary-text-color"><%= t.pages.myOrders.receiveEmail %>
							</span>
						</div>
						<div class="div justify-content-center align-items-center">
							<div class="switcher d-flex align-items-center radius-all-large active">
								<div class="ball radius-all-large bg-on-secondary-color"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		<section class="section">
			<%- include('../components/featurs/content.ejs', {featurs: t.pages.myAddress.components.featurs}); %>		
		</section>
	</main>










	<script src="../assets/vendors/swiper/swiper-bundle-min.js"></script>
	<script src="../assets/js/mizchin.min.js"></script>
	<script src="../assets/js/header.js"></script>

</body>

</html>