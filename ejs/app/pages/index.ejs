<%- include('../layouts/page/head.ejs', {pageName: "home"}); -%>

    <main>
        <section id="storyBox" class="section pt-0 px-xl-0">
            <div class="container overflow-x-scroll w-100 mr-lg-0 ml-lg-0 px-lg-0 py-lg-6 position-relative">
                <div class="card-container swiper w-100">
                    <div class="story-container px-4">
                        <div class="swiper-wrapper">
                            <% for(let i = 0; i < t.pages.home.storyBox.components.stories.length; i++){ -%>
                                <%- include('../components/story/content.ejs', {story: t.pages.home.storyBox.components.stories[i]}); %>
                            <%_ } -%>
                        </div>
                    </div>

                    <!-- Navigation Buttons -->
                    <div class="swiper-button-next">
                        <i class="fa-solid fa-chevron-right on-secondary-color"></i>
                    </div>

                    <div class="swiper-button-prev">
                        <i class="fa-solid fa-chevron-left on-secondary-color"></i>
                    </div>
                </div>
            </div>
        </section>
        <section id="hero" class="section w-100 px-0 py-0 position-relative">
            <div class="container d-flex overflow-hidden w-100 position-relative">
                <div class="slider slider-loop <%= t.pages.home.hero.enableSliderDraggable ? 'slider-draggable' : null %> d-flex flex-column align-items-center w-100" data-slider-timer="<%= t.pages.home.hero.dataSliderTimer %>">
                    <div class="slider-wrapper w-100">
                        <div class="slider-container">
                        <%_ for(let i = 0; i < t.pages.home.hero.sliders.length; i++){ -%>
                            <div id="<%= t.pages.home.hero.sliders[i].id %>" class="slider-content d-flex flex-column justify-content-center align-items-center">
                                <img src="<%= getMedia(lang, '', 'images'); %>" alt="" class="w-100 object-contain" />
                            </div>
                        <%_ } -%>
                        </div>
                    </div>
                    <%_ if(t.pages.home.hero.enableSliderToggles){ -%>
                    <div class="slider-toggles position-absolute gap-2 justify-content-start">
                        <%_ for(let i = 0; i < t.pages.home.hero.sliders.length; i++){ -%>
                            <div data-slider-id="<%= t.pages.home.hero.sliders[i].id %>" class="pagination slider-toggle aspect-ratio-1x1 radius-all-full"></div>
                        <%_ } -%>
                    </div>
                    <%_ } -%>
                </div>
            </div>
        </section>
        <section id="exceptionalOffers" class="section w-100 overflow-hidden">
            <div class="container w-100">
                <div class="block w-100 flex-lg-column align-items-stretch bg-primary-color radius-all-large pie-4 px-lg-4">
                    <div class="w-20 div justify-content-center position-relative px-5" style="width: 350px">
                        <div class="block flex-column flex-lg-row align-items-center h-100 justify-content-center pt-8 gap-8">
                            <img src="<%= getMedia(lang, '', 'images'); %>" alt="" class="w-90 d-lg-none" />
                            <img src="<%= getMedia(lang, '', 'images'); %>" alt="" class="w-50 d-none d-lg-block" />
                            <a href="<%= t.pages.home.exceptionalOffers.banner.link %>" class="div align-items-center gap-2 on-primary-color font-weight-bold">
                                <%= t.pages.home.exceptionalOffers.banner.title %>
                                <i class="fas fa-angle-left"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-container swiper w-100 w-80 w-xl-100 overflow-hidden py-8">
                        <div class="offer-card-content">
                            <div class="swiper-wrapper">
                                <%_ for(let i = 0; i < t.pages.home.exceptionalOffers.components.productCards.length; i++) { -%>
                                    <%- include('../components/product-card/full/content.ejs', {productCard: t.pages.home.exceptionalOffers.components.productCards[i], image: getMedia(lang, `products/mobile-${i + 1}.webp`, "images")}); %>
                                <%_ } -%>
                            </div>
                        </div>

                        <!-- Navigation Buttons -->
                        <div class="swiper-button-next">
                            <i class="fa-solid fa-chevron-right on-secondary-color"></i>
                        </div>

                        <div class="swiper-button-prev">
                            <i class="fa-solid fa-chevron-left on-secondary-color"></i>
                        </div>

                        <!-- Pagination -->
                        <!-- <div class="swiper-pagination"></div> -->
                    </div>
                </div>
            </div>
        </section>
        <section id="popularCategories" class="section w-100 overflow-hidden">
