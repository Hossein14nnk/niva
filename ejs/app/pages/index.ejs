                            <path d="M76.375 31.875L84.9763 37.031" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M75.2617 16.3672L85.01 22.2107" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M77.4883 8.63281L91.9676 17.3123" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M90.2812 8.61328L98.2167 13.3701" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M98.1875 13.75L84.9763 22.2629" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M98.1875 28.5195L84.9763 37.0325" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M84.9766 37.0312L84.9766 22.2632" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                            <path d="M98.1875 28.1875L98.1875 13.4194" stroke="#e80645" stroke-width="3" stroke-linecap="round"></path>
                        </svg>
                        <div class="line-horizental h-100"></div>
                        <p class="font-weight-bold secondary-text-color txt-size-big lh-5">
                            <%- t.pages.home.boxTaste.descriptions %>
                        </p>
                    </div>
                    <%- include('../components/see-all/content.ejs', {seeAll: t.pages.home.boxTaste.components.seeAll}); %>
