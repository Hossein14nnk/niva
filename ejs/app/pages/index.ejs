                                    <!-- src="<%= getMedia(lang, '', 'images'); %>" alt="" /> -->
                                    <img src="<%= getMedia(lang, '', 'images'); %>" alt="" />
                                </div>
                            <%_ } -%>
                            <div class="div w-100 h-100 justify-content-center align-items-center pt-1 radius-all-medium position-relative information-tooltip tooltip-top border-color bw-1 border-style-solid overflow-hidden">
                                <%- include('../components/see-all/content.ejs', {seeAll: t.pages.home.boxTaste.components.seeAll}); %>
