<%- include('../layouts/page/head.ejs', {pageName: "contactUs"}); -%>

	<main>
		<section id="contact-ways" class="section my-5 radius-all-small">
			<div class="d-flex flex-column gap-4 gap-xxl-2">
				<div class="d-flex flex-column gap-4 gap-xxl-2 flex-lg-column align-items-xl-center">
					<div class="i-shop d-flex flex-column w-100 gap-8 px-40 px-xl-0 w-md-100 align-items-center">
						<div class="d-flex justify-content-center flex-column align-items-center">
							<img class="w-50" src="<%= getMedia(lang, 'single/logo-web3.webp', 'images'); %>" />
							<p class="font-weight-bold txt-logo"><%= t.pages.contactUs.title %></p>
						</div>

						<div class="d-flex flex-column justify-content-center">
							<% for(let i = 0; i < t.components.contactUs.information.length; i++) {%>
								<%- include('../components/contact-us/information/content.ejs', {
									title: t.components.contactUs.information[i].title ,
									description: t.components.contactUs.information[i].description ,
									icon: t.components.contactUs.information[i].icon
								}); -%>
							<% } %>
						</div>

						<div class="d-flex w-100 justify-content-space-between flex-row-reverse">
							<% for(let i = 0; i < t.components.contactUs.socialMedia.length; i++) {%>
								<%- include('../components/contact-us/social-media/content.ejs', {
									name: t.components.contactUs.socialMedia[i].name ,
									icon: t.components.contactUs.socialMedia[i].icon
									
								}); -%>
							<% } %>
							
						</div>
					</div>
					<iframe class="w-100 radius-all-medium mt-12 w-xl-50 w-lg-100" src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d12951.109024056112!2d51.218427!3d35.7562792!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3f8de5006a0ba159%3A0x6ef7e9cb611a8298!2sivahid!5e0!3m2!1sen!2s!4v1728657276517!5m2!1sen!2s" width="600" style="border: 0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
				</div>
				<div class="wrapper-form w-100 py-7 px-8 radius-all-small w-xl-100 w-lg-100 pt-xxl-10 px-md-0">
					<form class="d-flex flex-column gap-4 w-100">
						<div class="w-100 d-grid grid-2 gap-4">
							<div class="w-100">
								<input class="text-color px-2 radius-all-small border-style-solid border-color bw-1 font-weight-bold txt-size-extra-title pb-2 pt-2 w-100" type="text" placeholder=<%= t.pages.contactUs.form.name %> />
							</div>
							<div class="w-100">
								<input type="email" class="px-2 text-color radius-all-small border-style-solid border-color bw-1 font-weight-bold txt-size-extra-title pb-2 pt-2 w-100" placeholder=<%= t.pages.contactUs.form.email %> />
							</div>
							<div class="w-100">
								<input type="text" class="px-2 text-color radius-all-small border-style-solid border-color bw-1 font-weight-bold txt-size-extra-title pb-2 pt-2 w-100" placeholder=<%= t.pages.contactUs.form.phone %>  />
							</div>
							<div class="w-100">
								<input type="text" class="px-2 text-color radius-all-small border-style-solid border-color bw-1 font-weight-bold txt-size-extra-title pb-2 pt-2 w-100" placeholder=<%= t.pages.contactUs.form.suggestion %>  />
							</div>
						</div>
						<div class="w-100">
							<textarea class="px-2 text-color border-style-solid radius-all-small border-color bw-1 font-weight-bold txt-size-extra-title pb-7 pt-2 text-justify w-100" placeholder=<%= t.pages.contactUs.form.description %>></textarea>
						</div>
						<div href="" class="send-btn w-100 bg-primary-color bg-btn-hover radius-all-small py-4 px-4 d-flex justify-content-center align-items-center gap-4 on-primary-color">
							<p class="txt-size-extra-title font-weight-bold"><%= t.pages.contactUs.form.send %></p>
						</div>
					</form>
				</div>
			</div>
		</section>
	</main>

<%- include('../layouts/page/foot.ejs'); %>
