
	<header id="header" class="section py-0 w-100 pie-0 pis-0 position-sticky top-0">
		<div class="container d-grid grid-1 w-100">
			<div class="primary-part w-100 d-flex pie-4 pis-4 gap-5 gap-sm-2 flex-row align-items-center justify-content-space-between bg-color">
				<div class="d-flex flex-row align-items-center justify-content-space-between gap-5 gap-sm-2">
					<a href="<%- navigation(lang , 'index.html') %>">
						<img src="<%= getMedia(lang, 'single/logo-web1.webp', 'images'); %>" alt="" class="logo h-75" />
					</a>
					<div id="searchBox">
						<div class="d-lg-flex">
							<input type="search" id="search" placeholder="<%= t.header.search.placeholder %>" class="bg-secondary-color py-4 pie-5 pis-5 radius-all-small d-lg-none" />
							<label for="search" class="pie-3 pis-3 aspect-ratio-1x1 d-none d-lg-flex align-items-center justify-content-center radius-all-small bg-secondary-color w-fit-content">
								<i class="fa-solid fa-magnifying-glass txt-size-mid-title"></i>
							</label>
						</div>
						<div class="content flex-column align-items-start gap-4 px-2 pb-2 pt-5 d-none bg-secondary-color w-100 radius-all-small w-lg-100">
							<div class="div align-items-center gap-2">
								<img src="<%= getMedia(lang, 'single/fire.svg', 'images'); %>" alt="" class="fire-svg" />
								<span class="black-text txt-size-title font-weight-bold"><%= t.header.search.popular.title %></span>
							</div>
							<div class="div align-items-center gap-3 flex-wrap">
								<%_ for(let i = 0; i < t.header.search.popular.items.length; i++){ -%>
									<button class="primary-btn cursor-pointer"><%= t.header.search.popular.items[i].title %></button>
								<%_ } -%>
							</div>
							<div class="line"></div>
							<div class="div align-items-center gap-2">
								<span class="black-text txt-size-title font-weight-bold"><%= t.header.search.history.title %></span>
							</div>
							<div class="div align-items-center gap-3 flex-wrap">
								<%_ for(let i = 0; i < t.header.search.history.items.length; i++){ -%>
									<button class="primary-btn cursor-pointer"><%= t.header.search.history.items[i].title %></button>
								<%_ } -%>
							</div>
						</div>
					</div>
					<div class="backdrop"></div>
					<a href="<%- navigation(lang , 'index.html') %>" class="location-btn d-sm-flex flex-row align-items-center radius-all-small pie-3 pis-3 py-3">
						<i class="fa-solid fa-location-dot text-color"></i>
					</a>
				</div>

				<div class="d-flex flex-row align-items-center gap-5 gap-sm-2">
					<i class="fa-solid fa-bell text-color"></i>
					<%_ if(t.header.login.loggedIn){ -%>
						<div class="profile dropdown bg-button-color bg-btn-hover radius-all-small">
							<div class="dropdown-box flex-row-reverse">
								<i class="fa-light fa-user txt-size-big-title"></i>
								<svg style="width: 20px; height: 20px;fill: var(--secondary);" viewBox="0 0 24 24">
									<path d="M7 10l5 5 5-5H7z"></path>
								</svg>
							</div>
							<ul class="dropdown-menu dropdown-bottom" style="width: 230px;">
								<li>
									<a href="<%- navigation(lang , 'index.html') %>" class="px-6 radius-tr-small radius-tl-small">
										<div class="w-100 d-flex flex-row-reverse align-items-center justify-content-space-between py-2">
											<span class="font-weight-medium txt-size-mid-title"><%= t.header.login.name %></span>
										</div>
									</a>
								</li>
								<%_ for(let i = 0; i < t.header.login.features.length; i++){ -%>
									<li>
										<a href="<%- navigation(lang , 'index.html') %>" class="px-6">
											<div class="w-100 d-flex flex-row-reverse align-items-center gap-5 py-1">
												<%- t.header.login.features[i].icon %>
			
												<div class="w-100 h-fit-content d-flex flex-row-reverse align-items-center">
													<span class="font-weight-medium txt-size-mid-title"><%= t.header.login.features[i].title %></span>
												</div>
											</div>
										</a>
									</li>
								<%_ } -%>
							</ul>
						</div>
					<%_ } else { -%>
						<a href="<%- navigation(lang , 'my-account.html') %>" class="d-flex flex-row align-items-center gap-2 gap-md-3 py-3 py-sm-3 pie-4 pis-4 bg-secondary-color radius-all-small">
							<i class="fa-solid fa-arrow-right-to-bracket text-color d-sm-none"></i>
							<span class="font-weight-bold text-color"><%= t.header.login.title %></span>
						</a>
					<%_ } -%>
					<div data-modal-id="cartProduct" class="modal-toggle cart-button bg-btn-hover d-flex flex-row align-items-center gap-2 gap-md-3 py-3 py-sm-3 pie-4 pis-4 bg-secondary-color radius-all-small bg-button-color">
						<span class="button-text-color font-weight-bold"><%= t.header.cartProduct.title %></span>
						<i class="fa-solid fa-bag-shopping button-text-color d-sm-none"></i>
					</div>
				</div>
			</div>

			<div class="secondary-part pie-4 pis-4 w-100 bg-color d-flex flex-row align-items-center justify-content-space-between">
				<nav>
					<ul class="hover-box d-flex flex-row align-items-stretch gap-6 gap-lg-4 gap-md-6 gap-sm-3">
						<li class="categories d-flex flex-row gap-4 align-items-center py-6 pie-md-4 pis-md-4 pie-sm-3 pis-sm-3">
							<i class="fa-solid fa-bars primary-color"></i>
							<span class="black-text txt-size-big font-weight-bold d-md-none"><%= t.header.menu.title %></span>
							<div class="megamenu d-none flex-row align-items-stretch">
								<ul class="d-flex flex-column bg-secondary-color position-relative">
									<%_ for(let i = 0; i < t.header.menu.categories.length; i++){ -%>
										<a href="<%= navigation(lang, 'shop.html'); %>">
											<li class="submenu-parent pie-sm-2 pis-sm-2 py-xl-3 d-flex flex-row align-items-center py-4 pie-5 pis-5 gap-2">
												<%- t.header.menu.categories[i].icon %>
												<span class="text-color txt-size-mid-title font-weight-bold"><%= t.header.menu.categories[i].title %></span>
												<div class="submenu d-<%= (i == 0) ? 'flex' : 'none' %> one position-absolute flex-column align-items-stretch gap-6 pie-1 pis-10 py-12">
													<span class="txt-size-mid-title text-color font-weight-bold line-height-3"><%= t.header.menu.viewAllText %> <%= t.header.menu.categories[i].title %></span>
													<ul class="h-100 d-flex flex-column flex-wrap gap-3">
														<%_ for(let j = 0; j < t.header.menu.categories[i].parents.length; j++){ -%>
															<li class="parent">
																<a class="txt-size-title font-weight-bold" href="<%= navigation(lang, 'shop.html'); %>"><%= t.header.menu.categories[i].parents[j].title %></a>
															</li>
															<%_ for(let k = 0; k < t.header.menu.categories[i].parents[j].items.length; k++){ -%>
																<li>
																	<a class="txt-size-title text-color font-weight-bold" href="<%= navigation(lang, 'simple-product.html'); %>"><%= t.header.menu.categories[i].parents[j].items[k].title %></a>
																</li>
															<%_ } -%>
														<%_ } -%>
													</ul>
												</div>
											</li>
										</a>
									<%_ } -%>
								</ul>
							</div>
						</li>
						<div class="vertical-line"></div>
						<%_ let j = null; -%>
						<%_ for(let i = 0; i < t.header.pages.length; i++){ -%>
							<%_ let menuPage = t.header.pages[i].items; -%>
							<%_ j++; -%>
							<li class="d-flex flex-row align-items-center <%= menuPage ? 'gap-2' : '' %>">
								<%_ if(!menuPage){ -%>
									<a href="<%= t.header.pages[i].link %>" class="d-flex flex-row align-items-center gap-2">
										<span class="txt-size-big font-weight-bold text-color"><%= t.header.pages[i].title %></span>
									</a>
								<%_ } else { -%>
									<span class="txt-size-big font-weight-bold text-color"><%= t.header.pages[i].title %></span>
									<i class="fa-solid fa-chevron-down txt-size-normal text-color"></i>
									<ul class="submenu-hover position-absolute bottom-0 right-0 left-sm-0 pis-8 pie-16 pie-xl-0 pie-xl-8 pis-xl-8 py-8 bg-color d-none align-items-start gap-6 gap-xl-4 <%= menuPage ? 'overflow-scroll' : '' %>">
										<%_ for(let k = 0; k < t.header.pages[i].items.length; k++){ -%>
											<li>
												<a href="<%= t.header.pages[i].items[k].link %>" class="text-color txt-size-title font-weight-bold"><%= t.header.pages[i].items[k].title %></a>
											</li>
										<%_ } -%>
									</ul>
								<%_ } -%>
							</li>

							<%_ if(j == t.header.pages.length - 1){ -%>
								<div class="vertical-line"></div>
							<%_ } -%>
						<%_ } -%>
					</ul>
				</nav>

				<div class="location-btn d-flex flex-row align-items-center gap-2 pie-8 pis-8 py-3 radius-all-small pie-sm-2 pis-sm-2 py-sm-2 d-sm-none">
					<span class="text-color font-weight-bold txt-size-title d-sm-none"><%= t.header.location.title %></span>
					<i class="fa-solid fa-location-dot text-color"></i>
				</div>
			</div>
		</div>
	</header>
